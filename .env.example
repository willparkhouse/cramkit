# ============================================================================
# cramkit env vars
# Copy to .env and fill in. Never commit .env.
# ============================================================================

# ---- Client (Vite) — also needed at docker build time ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ---- Server: Supabase ----
# Mirror of the two above (server reads non-VITE names)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Service role key — REQUIRED for admin routes & ingestion. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ---- Server: LLM providers ----
ANTHROPIC_API_KEY=sk-ant-api03-xxx
OPENAI_API_KEY=sk-proj-xxx

# ---- Server: auth / access ----
# Comma-separated allowlist of admin emails
ADMIN_EMAILS=you@example.com
# Comma-separated CORS origins for /api/*
CORS_ORIGINS=http://localhost:5173,https://cramkit.app

# ---- Server: Stripe ----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_1TJXqmRQQzfkSbxuebbOM1mo

# ---- Client: Stripe ----
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# ---- Server: runtime ----
PORT=3001
NODE_ENV=production
